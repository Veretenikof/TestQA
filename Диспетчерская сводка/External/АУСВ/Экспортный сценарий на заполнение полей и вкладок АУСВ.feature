	И добавляю дату и время начала в строку АУСВ, дата = "[ТДН]", время = "[ТВН]"
	И добавляю дату и время окончания в строку АУСВ, дата = "[ТДК]", время = "[ТВК]"
	И добавление КМЛ в строку АУСВ, кмл = "[ТекКМЛ]"
