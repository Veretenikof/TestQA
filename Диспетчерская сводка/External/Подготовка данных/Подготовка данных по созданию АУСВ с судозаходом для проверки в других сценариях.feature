Функционал: Подготовка данных по созданию АУСВ с судозаходом и судном
  

Контекст:
	Дано Я запускаю сценарий открытия TestClient или подключаю уже существующий

Сценарий: создаю АУСВ по судозаходу, ссылка на судозаход="ТекСсылка"

	// И я удаляю переменную '$$СудозаходСоСтрокамиИГрузовымИПланФактом$$'
	И Я запоминаю значение выражения 'ТекущаяДата()' в переменную "ТекущаяДата"
	И Я запоминаю значение выражения 'ТекущаяДата() + 86400' в переменную "СледующаяДата"
	И Я запоминаю значение выражения 'ТекущаяДата() + 172800' в переменную "ПослезавтраДата"
	И Я запоминаю значение выражения 'ТекущаяДата() - 99400' в переменную "ПредыдущаяДата"

	И я выполняю код встроенного языка
	"""bsl
	// 1. Генерируем UUID без дефисов для ссылки судна
	ЧистыйUid = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidСудна", ЧистыйUid);
	
	// 2. Генерируем 7 случайных цифр и СРАЗУ убираем пробелы через Формат
	Генератор = Новый ГенераторСлучайныхЧисел;
	ПолученноеЧисло = Генератор.СлучайноеЧисло(1111111, 9999999);
	ЦифрыИМО = Формат(ПолученноеЧисло, "ЧГ=");
	Контекст.Вставить("СлучайныйНомер", ЦифрыИМО);
	
	// 3. Собираем уникальные строки
	ИмяСудна = "ВА - судно для автотестов - " + ЦифрыИМО;
	Позывной = "Test" + ЦифрыИМО;
	СтрокаПоиска = ИмяСудна + "|" + Позывной;
	Контекст.Вставить("ТекИмяСудна", ИмяСудна);
	Контекст.Вставить("ТекПозывной", Позывной);
	Контекст.Вставить("ТекСтрокаПоиска", СтрокаПоиска);

	// 4. Строки для регистрации судов
	ЧистыйUid = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidРегистрацииСудна", ЧистыйUid);

	// 5. Генерируем UUID и сразу очищаем его от дефисов
	ЧистыйUid = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidСудозахода2", ЧистыйUid);

	// 6. Генерируем UUID операции и сразу очищаем его от дефисов
	ЧистыйUidОперации = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidОперации", ЧистыйUidОперации);

	// 7. Генерируем UUID план обработки груза и сразу очищаем его от дефисов
	ЧистыйUidПлана = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidПлана", ЧистыйUidПлана);

	ЧистыйUidПлана2 = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidПлана2", ЧистыйUidПлана2);

	// 8. Генерируем UUID факт обработки груза 1 и сразу очищаем его от дефисов
	ЧистыйUidФакта = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidФакта", ЧистыйUidФакта);

	// 8. Генерируем UUID факт обработки груза 2 и сразу очищаем его от дефисов
	ЧистыйUidФакта2 = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidФакта2", ЧистыйUidФакта2);
	// 9. Генерируем UUID АУСВ и сразу очищаем его от дефисов
	ЧистыйUidАУСВ = СтрЗаменить(Строка(Новый УникальныйИдентификатор), "-", "");
	Контекст.Вставить("УникальныйUidАУСВ", ЧистыйUidАУСВ);

	// Берем текущее время компьютера и сразу убираем время
	ТолькоДата = Формат(ТекущаяДата(), "ДФ=дд.ММ.гггг"); 
	Контекст.Вставить("ТекущаяДатаБезВремени", ТолькоДата);
	"""


